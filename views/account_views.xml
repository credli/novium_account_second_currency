<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record model="ir.ui.view" id="view_move_form_inherit_multicurrency_extend">
        <field name="name">account.move.form.inherit.multicurrency.extend</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='journal_line_ids']/list/field[@name='currency_id']"
                position="after">
                <field name="exchange_currency" optional="hide" force_save="1" invisible="1" />
                <field name="exchange_amount" widget="monetary"
                    column_invisible="parent.enable_second_currency_for_company == False"
                    options="{'currency_field': 'exchange_currency'}" force_save="1" invisible="1"
                />

                <field name="debit_exchange" optional="hide" widget="monetary"
                    column_invisible="parent.enable_second_currency_for_company == False"
                    options="{'currency_field': 'exchange_currency'}" force_save="1"
                    sum="Total Second Debit Amount"
                />

                <field name="credit_exchange" optional="hide" widget="monetary"
                    column_invisible="parent.enable_second_currency_for_company == False"
                    options="{'currency_field': 'exchange_currency'}" force_save="1"
                    sum="Total Second Credit Amount"
                />
            </xpath>

            <xpath expr="//group[@id='header_right_group']/div[@name='journal_div']"
                position="after">
                <field name="enable_second_currency_for_company" invisible="1" />
                <field name="company_second_currency_id" invisible="1" />
            </xpath>

            <xpath expr="//page[@id='aml_tab']//field[@name='currency_id']" position="replace">
                <field name="amount_currency"
                    groups="base.group_multi_currency"
                    optional="hide" />
            </xpath>

            <xpath expr="//page[@id='aml_tab']//field[@name='amount_currency']" position="replace">
                <field name="currency_id" options="{'no_create': True}"
                    groups="base.group_multi_currency"
                    column_invisible="parent.move_type != 'entry'" />
            </xpath>

            <xpath expr="//group[@id='header_right_group']//field[@name='invoice_date']"
                position="replace">
                <field name="invoice_date" nolabel="1"
                    options="{'datepicker': {'warn_future': true}}"
                    required="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')"
                    invisible="move_type not in ('out_invoice', 'out_refund', 'in_invoice', 'in_refund', 'out_receipt', 'in_receipt')" />
            </xpath>
        </field>
    </record>


    <record model="ir.ui.view" id="view_move_form_inherit_multicurrency_extend_items">
        <field name="name">account.move.line.form.inherit.multicurrency.extend</field>
        <field name="model">account.move.line</field>
        <field name="inherit_id" ref="account.view_move_line_tree" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='balance']" position="after">
                <field name="exchange_currency" force_save="1" optional="hide" />
                <field name="exchange_amount" widget="monetary" optional="hide"
                    options="{'currency_field': 'exchange_currency'}" force_save="1" invisible="1" />
                <field name="debit_exchange" widget="monetary" optional="hide"
                    options="{'currency_field': 'exchange_currency'}" force_save="1" />
                <field name="credit_exchange" widget="monetary" optional="hide"
                    options="{'currency_field': 'exchange_currency'}" force_save="1" />
            </xpath>
        </field>
    </record>

</odoo>